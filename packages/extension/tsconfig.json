{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@extension/*": [
        "./src/*"
      ],
      "@veganmage-ai-tab/shadui/*": [
        "../shadui/src/*"
      ],
      "@shadui/*": [
        "../shadui/src/*"
      ],
      "@veganmage-ai-tab/core/*": [
        "../core/src/*"
      ],
      "@core/*": [
        "../core/src/*"
      ],
      "@veganmage-ai-tab/ui/*": [
        "../ui/src/*"
      ],
      "@ui/*": [
        "../ui/src/*"
      ]
    }
  },
  "include": [
    "src",
    "wxt.config.ts",
    ".wxt/types/**/*.d.ts"
  ]
}
