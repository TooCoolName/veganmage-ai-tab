{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@ui/*": [
                "./src/*"
            ],
            "@veganmage-ai-tab/shadui/*": [
                "../shadui/src/*"
            ],
            "@shadui/*": [
                "../shadui/src/*"
            ],
            "@veganmage-ai-tab/core/*": [
                "../core/src/*"
            ],
            "@core/*": [
                "../core/src/*"
            ]
        }
    },
    "include": [
        "src/**/*",
        "src/**/*.svelte",
        "vite.config.ts"
    ]
}